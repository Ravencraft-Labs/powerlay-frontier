{
  "name": "powerlay",
  "version": "0.1.4",
  "private": true,
  "main": "packages/electron-shell/dist/main.js",
  "scripts": {
    "strip-types": "node scripts/strip-types.js",
    "strip-solarsystems": "node scripts/strip-solarsystems.js",
    "types-name-id": "node scripts/types-name-id.js",
    "dev": "concurrently -n d,o,e \"pnpm --filter @powerlay/ui-desktop dev\" \"pnpm --filter @powerlay/ui-overlay dev\" \"wait-on http://localhost:5173 http://localhost:5174 && cross-env DESKTOP_URL=http://localhost:5173 OVERLAY_URL=http://localhost:5174 pnpm --filter @powerlay/electron-shell dev\"",
    "build": "pnpm run -r build",
    "build:portable": "pnpm run build && electron-builder --win portable",
    "test": "pnpm run -r test",
    "lint": "pnpm run -r lint"
  },
  "build": {
    "appId": "com.powerlay.desktop",
    "productName": "Powerlay Frontier",
    "files": [
      "packages/electron-shell/dist/**"
    ],
    "extraResources": [
      {
        "from": "packages/ui-desktop/dist",
        "to": "desktop"
      },
      {
        "from": "packages/ui-overlay/dist",
        "to": "overlay"
      },
      {
        "from": "data",
        "to": "data",
        "filter": [
          "**/*",
          "!raw/types.json",
          "!raw/solarsystems.json"
        ]
      }
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.56.0",
    "wait-on": "^7.2.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0"
}
